generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Auth.js required models

model User {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts             Account[]
  sessions             Session[]
  teams                TeamMember[]
  assignedTasks        Task[]
  generatorsFixed      TaskGenerator[] @relation("FixedAssignee")
  generatorsLast       TaskGenerator[] @relation("LastAssignee")
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App models

enum AssignmentMode {
  fixed
  round_robin
}

enum TaskStatus {
  todo
  in_progress
  done
}

model Team {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  members   TeamMember[]
  projects  Project[]
  createdAt DateTime     @default(now())
}

model TeamMember {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId String @db.Uuid
  userId String @db.Uuid
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Project {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  teamId     String          @db.Uuid
  team       Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks      Task[]
  generators TaskGenerator[]
  createdAt  DateTime        @default(now())
}

model Task {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  status      TaskStatus     @default(todo)
  projectId   String         @db.Uuid
  assignedTo  String         @db.Uuid
  completedAt  DateTime?
  snoozedUntil DateTime?
  createdAt    DateTime       @default(now())
  generatorId String?        @db.Uuid
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User           @relation(fields: [assignedTo], references: [id])
  generator   TaskGenerator? @relation(fields: [generatorId], references: [id], onDelete: SetNull)
}

model TaskGenerator {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  projectId      String         @db.Uuid
  assignmentMode AssignmentMode
  fixedAssigneeId String?       @db.Uuid
  lastAssignedTo String?        @db.Uuid
  recurrenceRule String
  nextRunAt      DateTime
  createdAt      DateTime       @default(now())
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fixedAssignee  User?          @relation("FixedAssignee", fields: [fixedAssigneeId], references: [id])
  lastAssignee   User?          @relation("LastAssignee", fields: [lastAssignedTo], references: [id])
  tasks          Task[]
}
